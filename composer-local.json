{
  "name": "greenpeace/planet4-finland",
  "description": "Greenpeace P4 Finland",
  "license": "MIT",
  "require": {
    "greenpeace/planet4-master-theme": "v1.366.0",
    "greenpeace/planet4-child-theme-nordic" : "dev-develop",
    "greenpeace/planet4-gpnordic-plugin-leads": "dev-develop",
    "plugins/gravityformszapier": "*",
    "guzzlehttp/psr7": "2.10.1"
  },
  "scripts": {
    "core:language": "wp language core install fi; wp language core activate fi",
    "install:plugin-seoai-client_old": "wp plugin install --activate https://storage.googleapis.com/planet4-3rdparty-plugins/seoai-client_v2.22.8.zip",
    "install:plugin-seoai-client_new": "wp plugin install --activate https://storage.googleapis.com/planet4-3rdparty-plugins/seoai-client_v3.24.0.zip",
    "site:custom": [
      "@core:language",
      "@install:plugin-seoai-client_old",
      "@install:plugin-seoai-client_new"
    ]
  }
}
